{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/e2e/**/*.spec.ts"],
  "testTimeout": 60000,
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
