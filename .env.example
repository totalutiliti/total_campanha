# ============================================================================
# Total Campanha — .env.example
# Copie para .env e ajuste localmente. NUNCA commite .env (.gitignore protege).
# Em PROD, segredos sensíveis vivem em Key Vault e entram nos Container Apps
# como `secretref:` (ver instrucoes/instrucao_azure.md).
# ============================================================================

# ----- Ambiente -------------------------------------------------------------
NODE_ENV=development                       # development | staging | production
LOG_LEVEL=debug                            # trace | debug | info | warn | error
APP_NAME=total-campanha
APP_VERSION=0.0.1
TZ=America/Sao_Paulo

# ----- API ------------------------------------------------------------------
API_PORT=3001
API_BASE_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3001       # URL externa (usada em emails, webhooks)

# ----- Web (Next.js) --------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- CORS -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ----- Banco de dados (Postgres) -------------------------------------------
# Em DEV usa o postgres do docker-compose. Em PROD, Postgres Flexible Server
# com private endpoint + PgBouncer (porta 6432).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/total_campanha_dev?schema=public
# URL com role app_user (respeita RLS). Em DEV pode ser igual à DATABASE_URL.
DATABASE_APP_URL=postgresql://postgres:postgres@localhost:5432/total_campanha_dev?schema=public
# URL com role migration_user (BYPASSRLS) — usada apenas pelo passo `prisma migrate`.
DATABASE_MIGRATION_URL=postgresql://postgres:postgres@localhost:5432/total_campanha_dev?schema=public

# ----- Redis / BullMQ -------------------------------------------------------
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=tc

# ----- Auth (RULES seção 3) -------------------------------------------------
# Pepper Argon2id. Gere com: openssl rand -base64 48
AUTH_PEPPER=changeme-dev-pepper-pelo-amor-de-deus-troque-em-prod
# JWT
JWT_ACCESS_SECRET=changeme-dev-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=changeme-dev-refresh-secret
JWT_REFRESH_TTL=7d
# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false                        # true em staging/prod
COOKIE_SAMESITE=lax
# Reset de senha
PASSWORD_RESET_TTL_MIN=60

# ----- Criptografia BYOA (RULES seção 4) -----------------------------------
# Chave usada por pgcrypto.pgp_sym_encrypt para tokens WhatsApp.
# Em PROD vem do Key Vault. Em DEV, uma string longa qualquer serve.
TOKEN_KMS_KEY=changeme-dev-kms-key-troque-em-prod
# Token de verificação do webhook Meta (handshake GET) — pode ser por tenant
# se quisermos, mas começamos global no MVP.
META_WEBHOOK_VERIFY_TOKEN=changeme-dev-meta-verify-token

# ----- Meta (WhatsApp Cloud API) -------------------------------------------
META_GRAPH_VERSION=v22.0
META_GRAPH_BASE_URL=https://graph.facebook.com

# ----- Email -----------------------------------------------------------------
# Em DEV usamos MailHog (SMTP local). Em PROD, Amazon SES via SDK
# (MAIL_PROVIDER=ses EXIGE AWS_ACCESS_KEY_ID/SECRET — validado no boot).
# Vale para API e worker (o worker envia os e-mails de campanha).
MAIL_PROVIDER=smtp                         # smtp | ses | resend
MAIL_FROM_DEFAULT="Total Campanha <no-reply@totalcampanha.dev>"
# SMTP (DEV / MailHog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# Amazon SES (PROD)
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=
# Resend (alternativa SaaS)
RESEND_API_KEY=

# ----- Opt-in / Opt-out (RULES seção 5) ------------------------------------
CURRENT_OPT_IN_TERM_VERSION=2026-05-01
OPT_OUT_TOKEN_SECRET=changeme-dev-opt-out-hmac-secret
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ----- Billing --------------------------------------------------------------
BILLING_PROVIDER=asaas                     # asaas | stripe
ASAAS_API_KEY=
ASAAS_BASE_URL=https://www.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Observabilidade ------------------------------------------------------
APP_INSIGHTS_CONNECTION_STRING=
SENTRY_DSN=

# ----- Notificações internas ------------------------------------------------
SLACK_WEBHOOK_URL=                         # alertas de falha em massa, custo, etc.

# ----- Rate limit (RULES 3.4 e 7.1) ----------------------------------------
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MIN=15

# ----- Super Admin ----------------------------------------------------------
# Auditoria de impersonate: e-mail interno que recebe cópia.
SUPER_ADMIN_AUDIT_EMAIL=admin@totalutiliti.com.br

# ----- Storage (Azure Blob em PROD) ----------------------------------------
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=campanhas
AZURE_STORAGE_SAS=

# ----- Misc -----------------------------------------------------------------
# Domínio público de opt-in (usado para construir URLs nos emails/templates).
PUBLIC_OPT_IN_BASE_URL=http://localhost:3000/p/opt-in
PUBLIC_OPT_OUT_BASE_URL=http://localhost:3000/p/opt-out
# Base do app web para links em e-mails transacionais (ex.: redefinir senha).
# Opcional — sem ela, a API deriva a origem de PUBLIC_OPT_IN_BASE_URL.
WEB_BASE_URL=http://localhost:3000

# ----- BullMQ ---------------------------------------------------------------
# Tamanho a partir do qual a importação CSV de contatos vai para fila ao invés
# de processar síncrono no request (Fase 2.1).
CONTATOS_IMPORTAR_SYNC_LIMITE=1000

# ----- reCAPTCHA ------------------------------------------------------------
# Em DEV, deixar RECAPTCHA_SECRET vazio para pular a verificação.
# Em PROD é obrigatório (RULES 5 — defesa anti-bot no opt-in).
