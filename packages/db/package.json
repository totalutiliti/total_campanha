{
  "name": "@total-campanha/db",
  "version": "0.0.1",
  "private": true,
  "description": "Prisma schema + client compartilhado — Total Campanha.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "prisma": "prisma",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "studio": "prisma studio",
    "seed": "ts-node --transpile-only --project tsconfig.seed.json prisma/seed.ts",
    "criar-super-admin": "ts-node --transpile-only --project tsconfig.seed.json prisma/criar-super-admin.ts",
    "test": "jest --passWithNoTests",
    "test:rls": "jest tests/rls.test.ts --runInBand"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@testcontainers/postgresql": "^10.13.2",
    "@total-campanha/tsconfig": "workspace:*",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.14.10",
    "argon2": "^0.41.1",
    "jest": "^29.7.0",
    "prisma": "5.22.0",
    "testcontainers": "^10.13.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
