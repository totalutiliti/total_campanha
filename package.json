{
  "name": "total-campanha",
  "version": "0.0.1",
  "private": true,
  "description": "Total Campanha — plataforma SaaS B2B multi-tenant de campanhas Email + WhatsApp (BYOA).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || exit 0",
    "db:up": "docker compose up -d postgres redis mailhog",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres redis",
    "db:migrate": "pnpm --filter @total-campanha/db prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @total-campanha/db prisma migrate deploy",
    "db:generate": "pnpm --filter @total-campanha/db prisma generate",
    "db:seed": "pnpm --filter @total-campanha/db seed",
    "db:studio": "pnpm --filter @total-campanha/db prisma studio",
    "dev:api": "pnpm --filter @total-campanha/api dev",
    "dev:web": "pnpm --filter @total-campanha/web dev",
    "dev:worker": "pnpm --filter @total-campanha/worker dev",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:tenant-isolation": "pnpm --filter @total-campanha/api test:tenant-isolation",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\""
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "4.2.0",
      "lodash": "4.18.1",
      "multer": "2.2.0",
      "postcss": "8.5.10",
      "qs": "6.15.2"
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
