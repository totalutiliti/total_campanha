auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
engine-strict=true
prefer-frozen-lockfile=true

# Prisma vive em packages/db, mas seus tipos (Decimal, JsonValue) vazam para os
# controllers da API via @total-campanha/db. Hoistar @prisma/client para o
# node_modules raiz torna o caminho do tipo "nomeável" e portável — corrige
# TS2742 no `nest build` (que emite .d.ts).
public-hoist-pattern[]=@prisma/client
public-hoist-pattern[]=prisma
public-hoist-pattern[]=.prisma
